---
import Layout from '../layouts/Layout.astro';
---

<Layout title="International Journal of Computational Science and Technology (IJCST)">
  <main class="site-main" style="padding: 40px 20px; text-align: center;">
    <h1 style="font-size: 48px; margin-bottom: 20px;">International Journal of Computational Science and Technology (IJCST)</h1>
    <p style="font-size: 18px; margin-bottom: 30px; color: #555;">
      E‑ISSN : xxxx-xxxx | Quarterly — March, June, September, and December.
    </p>
    <img src="/IJCST.png" alt="IJCST Journal Cover" style="max-width: 300px; height: auto; border-radius: 8px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); margin-bottom: 30px;" />
    <p style="font-size: 16px; max-width: 800px; margin: 0 auto; color: #333;">
      Focuses on the latest advancements in computational research, algorithms, and engineering technology.
    </p>
    <a href="/journal/ijcst" class="btn btn-primary" style="margin-top: 20px; padding: 12px 24px; font-size: 16px;">View Journal</a>
    <br><br>
    <a href="/references" class="btn btn-primary" style="padding: 12px 24px; font-size: 16px;">View References</a>
  </main>
</Layout>
