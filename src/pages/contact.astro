---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us & Submit">
    <main class="site-main">
        <section style="background-color: var(--secondary-color); color: #fff; padding: 60px 20px; text-align: center;">
            <h1 style="font-size: 48px; margin-bottom: 15px; color: #fff;">Contact & Submission</h1>
            <p style="font-size: 18px; color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto;">Submit your manuscript or reach out to our editorial team.</p>
        </section>

        <section class="section-wrapper" style="max-width: 1200px; margin: 60px auto; padding: 0 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 60px;">
            <!-- Contact Info -->
            <div>
                <h2 style="font-size: 32px; margin-bottom: 20px; border-bottom: 2px solid var(--primary-color); display: inline-block; padding-bottom: 5px;">Get in Touch</h2>
                <p style="margin-bottom: 30px;">If you have any questions regarding manuscript submission, processing charges, or indexing, please feel free to contact us.</p>
                
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 18px; margin-bottom: 5px;">📍 Editorial Office</h3>
                    <p style="color: #666;">Rax Publications (Shanmuga Digital Premises), 5 , Jakkier Hussain Street , Opposite to Throwpathi Amman Kovil Arch, Sankarankovil - 627756 , Tamilnadu , India</p>
                </div>
                
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 18px; margin-bottom: 5px;">📧 Email Address</h3>
                    <p style="color: #666;">support@raxpublications.com<br>editor@raxpublications.com</p>
                </div>
                
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 18px; margin-bottom: 5px;">📞 Phone Number</h3>
                    <p style="color: #666;">+91 1234567890</p>
                </div>
            </div>

            <!-- Submission Form -->
            <div style="background: #fff; padding: 40px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #eee;">
                <h2 style="font-size: 28px; margin-bottom: 25px;">Submit Manuscript</h2>
                <form action="#" method="POST" style="display: flex; flex-direction: column; gap: 20px;">
                    <div>
                        <label for="author" style="display: block; font-weight: 600; margin-bottom: 5px;">Corresponding Author Name *</label>
                        <input type="text" id="author" name="author" required style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-family: var(--font-body);">
                    </div>
                    <div>
                        <label for="email" style="display: block; font-weight: 600; margin-bottom: 5px;">Email Address *</label>
                        <input type="email" id="email" name="email" required style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-family: var(--font-body);">
                    </div>
                    <div>
                        <label for="journal" style="display: block; font-weight: 600; margin-bottom: 5px;">Select Journal *</label>
                        <select id="journal" name="journal" required style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-family: var(--font-body);">
                            <option value="">-- Choose a Journal --</option>
                            <option value="ijcst">International Journal of Computational Science and Technology</option>
                            <option value="ijdsai">International Journal of Data Science and AI</option>
                        </select>
                    </div>
                    <div>
                        <label for="manuscript" style="display: block; font-weight: 600; margin-bottom: 5px;">Upload Manuscript (PDF/DOCX) *</label>
                        <input type="file" id="manuscript" name="manuscript" accept=".pdf,.doc,.docx" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-family: var(--font-body);">
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; font-size: 16px;">Submit Paper</button>
                </form>
            </div>
        </section>
    </main>
</Layout>
